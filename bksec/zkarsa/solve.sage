flag = 

A = 2**1000

L = -10**10000
R = 10**10000

for i, (e, y) in enumerate(zip(list_e, list_y)):
    Li = (y - A) // e
    Ri = y // e

    if Li > L:
        L = Li
    if Ri < R:
        R = Ri

    if (i+1) % 50 == 0:
        print(f"[{i+1}] interval size = {R-L}")

print("\n[+] Final interval:")
print("L =", L)
print("R =", R)
print("width =", R - L)